# Supabase Postgres connection string (must use the postgresql+asyncpg:// scheme)
DATABASE_URI="postgresql+asyncpg://USER:PASSWORD@HOST:PORT/postgres"

# Groq API key — powers IELTS/GRE grading, the chatbot, and university recommendations
GROQ_API_KEY=

# Secret used to sign JWTs
JWT_SECRET=

# Vercel frontend URL, e.g. https://your-app.vercel.app (enables CORS for it)
FRONTEND_ORIGIN=

# Set to "true" to force a CSV re-seed of the universities table on startup
FORCE_RESEED=
